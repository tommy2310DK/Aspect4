{
    "openapi": "3.0.2",
    "info": {
        "title": "Aspect4 Order API",
        "description": "API to fetch customer orders from Aspect4",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "https://aspect4-api-efacama5adafdvfd.westeurope-01.azurewebsites.net",
            "description": "Production Server"
        }
    ],
    "paths": {
        "/orders/{customer_id}": {
            "get": {
                "summary": "Get Customer Orders",
                "description": "Fetch orders for a specific customer.",
                "operationId": "GetCustomerOrders",
                "parameters": [
                    {
                        "name": "customer_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "description": "The ID of the customer to fetch orders for"
                    },
                    {
                        "name": "order_number",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        },
                        "description": "Specific order number to fetch"
                    },
                    {
                        "name": "days",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "description": "Number of days to look back"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "required": [
                                            "order_number",
                                            "order_date",
                                            "order_lines",
                                            "status_lines"
                                        ],
                                        "properties": {
                                            "order_number": {
                                                "type": "string"
                                            },
                                            "order_date": {
                                                "type": "string"
                                            },
                                            "order_lines": {
                                                "type": "array",
                                                "items": {
                                                    "type": "object",
                                                    "required": [
                                                        "varenr",
                                                        "quantity",
                                                        "unit_price",
                                                        "description",
                                                        "line_number",
                                                        "delivery_date",
                                                        "status"
                                                    ],
                                                    "properties": {
                                                        "varenr": {
                                                            "type": "string"
                                                        },
                                                        "quantity": {
                                                            "type": "string"
                                                        },
                                                        "unit_price": {
                                                            "type": "string"
                                                        },
                                                        "description": {
                                                            "type": "string"
                                                        },
                                                        "line_number": {
                                                            "type": "string"
                                                        },
                                                        "delivery_date": {
                                                            "type": "string"
                                                        },
                                                        "status": {
                                                            "type": "string"
                                                        }
                                                    }
                                                }
                                            },
                                            "status_lines": {
                                                "type": "array",
                                                "items": {
                                                    "type": "object",
                                                    "required": [
                                                        "varenr",
                                                        "quantity",
                                                        "unit_price",
                                                        "description",
                                                        "line_number",
                                                        "delivery_date",
                                                        "status"
                                                    ],
                                                    "properties": {
                                                        "varenr": {
                                                            "type": "string"
                                                        },
                                                        "quantity": {
                                                            "type": "string"
                                                        },
                                                        "unit_price": {
                                                            "type": "string"
                                                        },
                                                        "description": {
                                                            "type": "string"
                                                        },
                                                        "line_number": {
                                                            "type": "string"
                                                        },
                                                        "delivery_date": {
                                                            "type": "string"
                                                        },
                                                        "status": {
                                                            "type": "string"
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}